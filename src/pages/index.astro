---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/ui/navbar";
import { auth } from "../lib/auth";

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});
---

<Layout title="Ringkas - Solusi Link Kampus Polida Blokagung">
  <div class="min-h-screen bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 flex flex-col font-sans selection:bg-blue-500/30 selection:text-blue-900 dark:selection:text-blue-100">
    <Navbar client:load session={session} />

    {/* Hero Section */}
    <main class="flex-grow flex flex-col items-center justify-center relative overflow-hidden pt-32 pb-20 px-6">
      {/* Square Grid Background */}
      <div class="absolute inset-0 z-0 opacity-[0.03] dark:opacity-[0.06]" 
           style="background-image: linear-gradient(#000 1.2px, transparent 1.2px), linear-gradient(90deg, #000 1.2px, transparent 1.2px); background-size: 32px 32px;"></div>
      <div class="absolute inset-0 z-0 opacity-[0.02] dark:opacity-[0.04]" 
           style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 8px 8px;"></div>
      
      {/* Glow Effects */}
      <div class="absolute top-1/4 -left-20 w-80 h-80 bg-blue-500/10 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-1/4 -right-20 w-80 h-80 bg-purple-500/10 rounded-full blur-[100px] animate-pulse" style="animation-delay: 2s;"></div>

      <div class="relative z-10 max-w-5xl mx-auto text-center space-y-12">
        {/* Badge */}
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-600 dark:text-blue-400 text-xs font-black uppercase tracking-[0.2em] animate-fade-in">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          Portal URL Internal Kampus
        </div>

        {/* Headline */}
        <h1 class="text-6xl md:text-8xl font-black tracking-tight leading-[0.9] text-gray-900 dark:text-white">
          Sederhanakan <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600">Terhubung.</span>
        </h1>

        <p class="max-w-2xl mx-auto text-lg md:text-xl font-medium text-gray-500 dark:text-gray-400 leading-relaxed italic">
          Platform manajemen link terpadu untuk civitas akademika 
          <span class="text-gray-900 dark:text-white not-italic font-black mx-1">Politeknik Darussalam Blokagung.</span>
          Canggih, Cepat, dan Aman.
        </p>

        {/* Buttons */}
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 pt-4">
          {session ? (
            <a
              href="/dashboard"
              class="group px-10 py-5 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-black text-sm uppercase tracking-widest rounded-2xl shadow-2xl hover:scale-105 active:scale-95 transition-all flex items-center gap-3"
            >
              Kembali ke Dashboard
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          ) : (
            <>
              <a
                href="/register"
                class="group px-10 py-5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-black text-sm uppercase tracking-widest rounded-2xl shadow-2xl shadow-blue-500/25 hover:scale-105 active:scale-95 transition-all flex items-center gap-3"
              >
                Mulai Sekarang
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a
                href="/login"
                class="px-10 py-5 bg-white dark:bg-gray-900 border-2 border-gray-100 dark:border-gray-800 text-gray-900 dark:text-white font-black text-sm uppercase tracking-widest rounded-2xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-all flex items-center gap-3"
              >
                Masuk Portal
              </a>
            </>
          )}
        </div>

        {/* Stats Preview */}
        <div class="pt-20 grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-700">
           <div class="flex flex-col items-center">
             <span class="text-3xl font-black">10K+</span>
             <span class="text-[10px] uppercase font-bold tracking-widest">Link Dibuat</span>
           </div>
           <div class="flex flex-col items-center">
             <span class="text-3xl font-black">50K+</span>
             <span class="text-[10px] uppercase font-bold tracking-widest">Total Klik</span>
           </div>
           <div class="flex flex-col items-center">
             <span class="text-3xl font-black">99.9%</span>
             <span class="text-[10px] uppercase font-bold tracking-widest">Uptime</span>
           </div>
           <div class="flex flex-col items-center">
             <span class="text-3xl font-black">24/7</span>
             <span class="text-[10px] uppercase font-bold tracking-widest">Support</span>
           </div>
        </div>
      </div>
    </main>

    {/* Simple Footer */}
    <footer class="py-12 border-t border-gray-100 dark:border-gray-900 text-center">
      <p class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400">
        &copy; 2026 Politeknik Darussalam Blokagung. All Rights Reserved.
      </p>
    </footer>
  </div>
</Layout>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }
  .animate-shake {
    animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
  }
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
</style>
